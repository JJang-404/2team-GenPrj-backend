# ─── Node.js 백엔드 (backend/) ────────────────────────────────────────────────
# 서버 포트 (기본값 4000)
PORT=4000
HOST=127.0.0.1

# HuggingFace API — AI 배경 생성 및 배경 제거 기능에 필요
# https://huggingface.co/settings/tokens 에서 발급
# 이 키 없이도 단색/그라데이션/다중색 배경 생성은 작동함
HF_TOKEN=hf_your_token_here

# HuggingFace 모델 설정 (선택)
# HF_BG_REMOVAL_MODEL=briaai/RMBG-2.0
# HF_IMAGE_TO_IMAGE_MODEL=stabilityai/stable-diffusion-3.5-medium
# HF_GUIDANCE_SCALE=6
# HF_NUM_INFERENCE_STEPS=30
# HF_TARGET_WIDTH=768
# HF_TARGET_HEIGHT=1024

# OpenAI API — 한→영 프롬프트 번역에 사용 (선택, 없으면 기본 번역 사용)
# https://platform.openai.com/api-keys 에서 발급
# OPENAI_API_KEY=sk-your_key_here
# OPENAI_TRANSLATION_MODEL=gpt-4o-mini
